{
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "make",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make clean",
            "group": "build"
        },
        {
            "label": "Docker Build",
            "type": "shell",
            "command": "docker build -t my-app .",
            "group": "build"
        },
        {
            "label": "Docker Run",
            "type": "shell",
            "command": "docker run --rm my-app",
            "group": "test"
        }
    ],
    "version": "2.0.0"
}